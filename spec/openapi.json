  "components": {
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Authentication via API key"
      }
    },
    "schemas": {
      "AddEvent": {
        "description": "Event to ingest / add to the stream",
        "type": "object",
        "properties": {
          "data": {
            "description": "Event data",
            "type": [
              "string",
              "null"
            ]
          },
          "event": {
            "description": "Name/type of the event",
            "type": "string"
          }
        },
        "required": [
          "event"
        ]
      },
      "AddEventsRequest": {
        "type": "object",
        "properties": {
          "events": {
            "description": "Events to add to the stream",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AddEvent"
            }
          },
          "key": {
            "description": "Key of the stream to write to",
            "type": "string"
          }
        },
        "required": [
          "key",
          "events"
        ]
      },
      "AddEventsResponse": {
        "type": "object",
        "properties": {
          "num_events": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          }
        },
        "required": [
          "num_events"
        ]
      },
      "EndStreamResponse": {
        "type": "object",
        "properties": {
          "status": {
            "description": "Status of the stream",
            "allOf": [
              {
                "$ref": "#/components/schemas/StreamStatus"
              }
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "ErrorBody": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "format": "uint16",
            "maximum": 65535,
            "minimum": 0
          }
        },
        "required": [
          "message",
          "status"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorBody"
          }
        },
        "required": [
          "error"
        ]
      },
      "InfoResponse": {
        "type": "object",
        "properties": {
          "redis": {
            "$ref": "#/components/schemas/RedisStats"
          },
          "url": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "url",
          "version",
          "redis"
        ]
      },
      "RedisStats": {
        "type": "object",
        "properties": {
          "static": {
            "description": "Number of static connections",
            "type": "integer",
            "format": "uint",
            "minimum": 0
          },
          "streaming_available": {
            "description": "Number of available streaming connections",
            "type": "integer",
            "format": "uint",
            "minimum": 0
          },
          "streaming_in_use": {
            "description": "Number of in-use streaming connections",
            "type": "integer",
            "format": "uint",
            "minimum": 0
          },
          "streaming_max": {
            "description": "Maximum number of streaming connections",
            "type": "integer",
            "format": "uint",
            "minimum": 0
          }
        },
        "required": [
          "static",
          "streaming_in_use",
          "streaming_available",
          "streaming_max"
        ]
      },
      "StreamAccessResponse": {
        "type": "object",
        "properties": {
          "sse_url": {
            "description": "URL for the client to connect to the stream via SSE",
            "type": "string"
          },
          "token": {
            "description": "Client token to access the stream. Can be used as a Bearer token\nin the Authorization header (recommended) or as the `token` query parameter.",
            "type": "string"
          },
          "ws_url": {
            "description": "URL for the client to connect to the stream via WebSocket",
            "type": "string"
          }
        },
        "required": [
          "sse_url",
          "ws_url",
          "token"
        ]
      },
      "StreamEvent": {
        "description": "Formatted stream event",
        "type": "object",
        "properties": {
          "data": {
            "description": "Event data",
            "type": [
              "string",
              "null"
            ]
          },
          "event": {
            "description": "Name/type of the event",
            "type": "string"
          },
          "id": {
            "description": "ID of the event",
            "type": "string"
          },
          "time": {
            "description": "Time of the event (ISO 8601 format)",
            "type": "string"
          }
        },
        "required": [
          "id",
          "time",
          "event"
        ]
      },
      "StreamInfo": {
        "description": "Information about the stream",
        "type": "object",
        "properties": {
          "key": {
            "description": "Key of the stream in Redis",
            "type": "string"
          },
          "length": {
